# Proxmox connection and UI authentication are configured from the ProxCenter interface
# and stored in ./data (persistent Docker volume). This file is optional.

# GreenIT advisor calibration (MVP heuristic)
# PUE example: 1.2 (optimized DC) to 2.0+ (small room / homelab)
GREENIT_PUE=1.45
# kg CO2 per kWh (adjust to your electricity mix / country)
GREENIT_CO2_FACTOR_KG_PER_KWH=0.052
# Electricity price in EUR per kWh (used for annual cost estimate)
GREENIT_ELECTRICITY_PRICE=0.18

# Cloud OAuth broker (only if you expose a central broker publicly)
# Comma- or space-separated origins allowed to receive the OAuth refresh token.
# Example: PROXMOXCENTER_CLOUD_OAUTH_BROKER_ALLOWED_ORIGINS=http://localhost:3000 https://proxmox.exemple.fr
# PROXMOXCENTER_CLOUD_OAUTH_BROKER_ALLOWED_ORIGINS=
